# ─────────────────────────────────────────────────────────────
# DriveLegal — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────
# PostgreSQL 16 with PostGIS 3.4 extension required
# Default local Docker config: postgresql://drivelegal:drivelegal@localhost:5432/drivelegal
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/drivelegal

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── OpenAI (Optional) ────────────────────────────────────────
# If not provided, the system automatically falls back to
# the offline Xenova/all-MiniLM-L6-v2 model for embeddings
# and template-based answer synthesis (no LLM call).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

# ── Public URL ───────────────────────────────────────────────
# Base URL used to construct evidence/citation links in responses
EVIDENCE_PUBLIC_URL=http://localhost:4000

# ── Admin API ────────────────────────────────────────────────
# Used to protect rule verification and admin stats endpoints.
# Generate a strong random value for any non-local deployment.
# Example (Linux/macOS): openssl rand -hex 32
ADMIN_API_KEY=change-me-use-a-strong-random-secret

# ── Retrieval Tuning (Optional) ──────────────────────────────
# Cosine similarity thresholds for semantic retrieval.
# Lower = more permissive (more results, potentially noisier).
# Higher = stricter (fewer, higher-confidence results).
RULE_SIMILARITY_THRESHOLD=0.38
CHUNK_SIMILARITY_THRESHOLD=0.33
